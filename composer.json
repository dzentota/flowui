{
    "name": "flowui/flowui",
    "description": "FlowUI - Progressive PHP Framework for Rapid UI Development",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "FlowUI Contributors"
        }
    ],
    "require": {
        "php": ">=7.4",
        "masterminds/html5": "^2.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "FlowUI\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FlowUI\\Tests\\": "tests/"
        }
    }
}
